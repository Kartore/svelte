{
	"name": "svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"deploy": "vite build && wrangler deploy",
		"test": "vitest run",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check || svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"gen": "wrangler types"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "next",
		"@sveltejs/kit": "next",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.3",
		"@types/node": "^26.1.1",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.21.0",
		"globals": "^17.6.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.3.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10",
		"wrangler": "^4.112.0"
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.3",
		"@codemirror/commands": "^6.10.4",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/language": "^6.12.4",
		"@codemirror/lint": "^6.9.7",
		"@codemirror/state": "^6.7.1",
		"@codemirror/view": "^6.43.6",
		"@internationalized/number": "^3.6.7",
		"@kartore-internal/github-adapter": "0.3.0",
		"@kartore/file-adapter": "0.2.0",
		"@kartore/glyphore": "^0.2.0",
		"@kartore/spritore": "^0.2.0",
		"@maplibre/maplibre-gl-style-spec": "^26.1.0",
		"@tanstack/svelte-query": "^6.1.36",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"fflate": "^0.8.3",
		"maplibre-gl": "^5.24.0",
		"svelte-maplibre-gl": "^2.1.0",
		"tailwind-merge": "^3.6.0"
	},
	"packageManager": "pnpm@11.13.1",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "26.5.0",
			"onFail": "download"
		}
	}
}
